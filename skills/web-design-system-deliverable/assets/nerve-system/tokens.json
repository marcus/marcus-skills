      },
      "blue": {
        "700": "#1D4ED8",
        "600": "#2563EB",
        "500": "#3B82F6",
        "400": "#60A5FA",
        "300": "#93C5FD",
        "200": "#BFDBFE"
      }
    },
    "spacing": {
      "0": "0",
      "px": "1px",
      "0-5": "0.125rem",
      "1": "0.25rem",
      "1-5": "0.375rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.5rem",
      "6": "2rem",
      "7": "2.5rem",
      "8": "3rem",
      "9": "4rem",
      "10": "5rem",
      "11": "6rem",
      "12": "8rem"
    },
    "radius": {
      "0": "0",
      "1": "2px",
      "2": "4px",
      "3": "6px",
      "4": "8px",
      "5": "12px",
      "full": "9999px"
    },
    "typography": {
      "families": {
        "display": "'Space Grotesk', 'Inter', system-ui, -apple-system, sans-serif",
        "body": "'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif",
        "mono": "'JetBrains Mono', 'Fira Code', 'SF Mono', 'Cascadia Code', monospace"
      },
      "scale": {
        "00": "0.6875rem",
        "0": "0.8125rem",
        "1": "0.9375rem",
        "2": "1.0625rem",
        "3": "clamp(1.1875rem, 1.1rem + 0.4vw, 1.3125rem)",
        "4": "clamp(1.375rem, 1.15rem + 0.75vw, 1.625rem)",
        "5": "clamp(1.75rem, 1.35rem + 1.3vw, 2.25rem)",
        "6": "clamp(2.75rem, 1.75rem + 3.3vw, 5rem)"
      },
      "lineHeight": {
        "none": 1,
        "tight": 1.1,
        "snug": 1.25,
        "body": 1.55,
        "loose": 1.75
      },
      "letterSpacing": {
        "tighter": "-0.03em",
        "tight": "-0.015em",
        "normal": "0",
        "wide": "0.025em",
        "wider": "0.05em",
        "label": "0.08em"
      },
      "weight": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      }
    },
    "motion": {
      "duration": {
        "micro": "50ms",
        "fast": "100ms",
        "base": "150ms",
        "moderate": "240ms",
        "slow": "360ms",
        "dramatic": "500ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.16, 0.7, 0.3, 1)",
        "emphasis": "cubic-bezier(0.12, 1, 0.2, 1)",
        "decelerate": "cubic-bezier(0, 0, 0.15, 1)",
        "accelerate": "cubic-bezier(0.5, 0, 1, 1)",
        "spring": "cubic-bezier(0.34, 1.4, 0.64, 1)"
      },
      "staggerDelay": "50ms"
    },
    "contentWidth": {
      "narrow": "42rem",
      "medium": "56rem",
      "wide": "76rem",
      "max": "90rem"
    },
    "breakpoints": {
      "compact": "0",
      "medium": "48rem",
      "expanded": "64rem",
      "wide": "90rem"
    }
  },
  "semantic": {
    "dark": {
      "background": {
        "canvas": "{void.900}",
        "surface": "{void.800}",
        "elevated": "{void.700}",
        "sunken": "{void.950}",
        "inverse": "{void.50}",
        "soft": "{void.850}"
      },
      "foreground": {
        "strong": "{void.50}",
        "default": "{void.100}",
        "muted": "{void.200}",
        "subtle": "{void.300}",
        "disabled": "{void.400}",
        "inverse": "{void.900}",
        "onAccent": "#FFFFFF"
      },
      "border": {
        "subtle": "rgba(255,255,255,0.06)",
        "default": "rgba(255,255,255,0.1)",
        "strong": "rgba(255,255,255,0.18)"
      },
      "accent": {
        "brand": "{violet.600}",
        "brandHover": "{violet.500}",
        "brandPressed": "{violet.700}",
        "brandSubtle": "rgba(124,58,237,0.15)",
        "brandFg": "{violet.400}",
        "secondary": "{cyan.500}",
        "secondaryHover": "{cyan.400}",
        "secondarySubtle": "rgba(6,182,212,0.15)",
        "secondaryFg": "{cyan.400}"
      },
      "feedback": {
        "success": "{green.500}",
        "successSubtle": "rgba(16,185,129,0.12)",
        "successFg": "{green.400}",
        "warning": "{amber.500}",
        "warningSubtle": "rgba(245,158,11,0.12)",
        "warningFg": "{amber.400}",
        "danger": "{red.500}",
        "dangerSubtle": "rgba(239,68,68,0.12)",
        "dangerFg": "{red.400}",
        "info": "{blue.500}",
        "infoSubtle": "rgba(59,130,246,0.12)",
        "infoFg": "{blue.400}"
      },
      "focus": {
        "ring": "{violet.500}",
        "ringOffset": "{void.900}"
      }
    },
    "light": {
      "background": {
        "canvas": "#FAFAFA",
        "surface": "#FFFFFF",
        "elevated": "#FFFFFF",
        "sunken": "#F0F0F3",
        "inverse": "{void.900}",
        "soft": "#F4F4F6"
      },
      "foreground": {
        "strong": "{void.900}",
        "default": "{void.800}",
        "muted": "{void.400}",
        "subtle": "{void.300}",
        "disabled": "{void.200}",
        "inverse": "{void.50}",
        "onAccent": "#FFFFFF"
      },
      "border": {
        "subtle": "rgba(0,0,0,0.06)",
        "default": "rgba(0,0,0,0.1)",
        "strong": "rgba(0,0,0,0.18)"
      },
      "accent": {
        "brand": "{violet.600}",
        "brandHover": "{violet.700}",
        "brandPressed": "{violet.800}",
        "brandSubtle": "rgba(124,58,237,0.08)",
        "brandFg": "{violet.700}",
        "secondary": "{cyan.600}",
        "secondaryHover": "{cyan.700}",
        "secondarySubtle": "rgba(6,182,212,0.08)",
        "secondaryFg": "{cyan.700}"
      },
      "feedback": {
        "success": "{green.600}",
        "successSubtle": "rgba(5,150,105,0.08)",
        "successFg": "{green.700}",
        "warning": "{amber.600}",
        "warningSubtle": "rgba(217,119,6,0.08)",
        "warningFg": "{amber.700}",
        "danger": "{red.600}",
        "dangerSubtle": "rgba(220,38,38,0.08)",
        "dangerFg": "{red.700}",
        "info": "{blue.600}",
        "infoSubtle": "rgba(37,99,235,0.08)",
        "infoFg": "{blue.700}"
      },
      "focus": {
        "ring": "{violet.500}",
        "ringOffset": "#FFFFFF"
      }
    }
  },
  "component": {
    "button": {
      "primary": {
        "bg": "{accent.brand}",
        "bgHover": "{accent.brandHover}",
        "bgActive": "{accent.brandPressed}",
        "fg": "{foreground.onAccent}"
      },
      "secondary": {
        "bg": "transparent",
        "bgHover": "{accent.brandSubtle}",
        "fg": "{accent.brandFg}",
        "border": "{border.strong}"
      },
      "ghost": {
        "bg": "transparent",
        "bgHover": "rgba(255,255,255,0.06)",
        "fg": "{foreground.muted}",
        "fgHover": "{foreground.strong}"
      },
      "danger": {
        "bg": "{feedback.danger}",
        "bgHover": "{feedback.dangerStrong}",
        "fg": "#FFFFFF"
      }
    },
    "input": {
      "bg": "{background.soft}",
      "bgHover": "{background.elevated}",
      "border": "{border.default}",
      "borderFocus": "{accent.brand}",
      "borderError": "{feedback.danger}",
      "fg": "{foreground.strong}",
      "placeholder": "{foreground.subtle}"
    },
    "card": {
      "bg": "{background.surface}",
      "border": "{border.subtle}",
      "borderHover": "{border.default}"
    },
    "table": {
      "headerBg": "{background.soft}",
      "headerFg": "{foreground.subtle}",
      "rowBorder": "{border.subtle}",
      "rowHover": "rgba(255,255,255,0.03)"
    },
    "navigation": {
      "bg": "{background.sunken}",
      "itemFg": "{foreground.muted}",
      "itemFgHover": "{foreground.strong}",
      "itemFgActive": "{accent.brandFg}",
      "itemBgActive": "{accent.brandSubtle}"
    }
  },
  "radius": {
    "semantic": {
      "structural": "{radius.1}",
      "interactive": "{radius.3}",
      "signature": "{radius.4}",
      "data": "{radius.0}",
      "badge": "{radius.full}"
    }
  },
  "dataVisualization": {
    "palette": [
      { "order": 1, "token": "dataviz-1", "role": "Primary series", "dark": "#8B5CF6", "light": "#7C3AED" },
      { "order": 2, "token": "dataviz-2", "role": "Secondary series", "dark": "#22D3EE", "light": "#0891B2" },
      { "order": 3, "token": "dataviz-3", "role": "Tertiary series", "dark": "#34D399", "light": "#059669" },
      { "order": 4, "token": "dataviz-4", "role": "Quaternary series", "dark": "#FBBF24", "light": "#D97706" },
      { "order": 5, "token": "dataviz-5", "role": "Quinary series", "dark": "#F87171", "light": "#DC2626" },
      { "order": 6, "token": "dataviz-6", "role": "Senary series", "dark": "#60A5FA", "light": "#2563EB" },
      { "order": 7, "token": "dataviz-neutral", "role": "Baseline / other", "dark": "#52526B", "light": "#71717A" },
      { "order": 8, "token": "dataviz-emphasis", "role": "Highlighted point", "dark": "#C4B5FD", "light": "#5B21B6" }
    ]
  }
