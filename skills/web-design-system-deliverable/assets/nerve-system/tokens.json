        "300": "#FCD34D",
        "200": "#FDE68A"
      },
      "red": {
        "800": "#991B1B",
        "700": "#B91C1C",
        "600": "#DC2626",
        "500": "#EF4444",
        "400": "#F87171",
        "300": "#FCA5A5",
