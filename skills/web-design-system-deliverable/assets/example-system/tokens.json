{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meridian": {
    "$description": "Meridian Design System — Token definitions following W3C Design Tokens format",

    "primitive": {
      "color": {
        "neutral": {
          "0":    { "$value": "#000000", "$type": "color" },
          "50":   { "$value": "#0A0A08", "$type": "color" },
          "100":  { "$value": "#121210", "$type": "color" },
          "150":  { "$value": "#1A1A17", "$type": "color" },
          "200":  { "$value": "#232320", "$type": "color" },
          "250":  { "$value": "#2C2C28", "$type": "color" },
          "300":  { "$value": "#38372F", "$type": "color" },
          "400":  { "$value": "#504E46", "$type": "color" },
          "500":  { "$value": "#6E6C62", "$type": "color" },
          "600":  { "$value": "#8E8B80", "$type": "color" },
          "700":  { "$value": "#B0ADA2", "$type": "color" },
          "800":  { "$value": "#D0CDC2", "$type": "color" },
          "900":  { "$value": "#E8E6DC", "$type": "color" },
          "950":  { "$value": "#F5F3E9", "$type": "color" },
          "1000": { "$value": "#FFFFFF", "$type": "color" }
        },
        "amber": {
          "50":  { "$value": "#1A1408", "$type": "color" },
          "100": { "$value": "#2A200C", "$type": "color" },
          "200": { "$value": "#3E3010", "$type": "color" },
          "300": { "$value": "#5C4818", "$type": "color" },
          "400": { "$value": "#8A6C24", "$type": "color" },
          "500": { "$value": "#C49430", "$type": "color" },
          "600": { "$value": "#E0AC3C", "$type": "color" },
          "700": { "$value": "#F0C45C", "$type": "color" },
          "800": { "$value": "#F8D880", "$type": "color" },
          "900": { "$value": "#FFF0C0", "$type": "color" }
        },
        "teal": {
          "50":  { "$value": "#081A16", "$type": "color" },
          "100": { "$value": "#0C2A22", "$type": "color" },
          "200": { "$value": "#103C32", "$type": "color" },
          "300": { "$value": "#18584A", "$type": "color" },
          "400": { "$value": "#207862", "$type": "color" },
          "500": { "$value": "#2C9A7E", "$type": "color" },
          "600": { "$value": "#38B890", "$type": "color" },
          "700": { "$value": "#5CCCA8", "$type": "color" },
          "800": { "$value": "#88DCC0", "$type": "color" },
          "900": { "$value": "#C0F0E0", "$type": "color" }
        },
        "red": {
          "50":  { "$value": "#1C0808", "$type": "color" },
          "100": { "$value": "#2C1010", "$type": "color" },
          "200": { "$value": "#441818", "$type": "color" },
          "300": { "$value": "#6C2424", "$type": "color" },
          "400": { "$value": "#983030", "$type": "color" },
          "500": { "$value": "#C44040", "$type": "color" },
          "600": { "$value": "#E05050", "$type": "color" },
          "700": { "$value": "#F07070", "$type": "color" },
          "800": { "$value": "#F8A0A0", "$type": "color" },
          "900": { "$value": "#FCE0E0", "$type": "color" }
        },
        "blue": {
          "50":  { "$value": "#080E1C", "$type": "color" },
          "100": { "$value": "#101C30", "$type": "color" },
          "200": { "$value": "#182C48", "$type": "color" },
          "300": { "$value": "#244468", "$type": "color" },
          "400": { "$value": "#306090", "$type": "color" },
          "500": { "$value": "#4080B8", "$type": "color" },
          "600": { "$value": "#5098D0", "$type": "color" },
          "700": { "$value": "#70B0E0", "$type": "color" },
          "800": { "$value": "#A0CCF0", "$type": "color" },
          "900": { "$value": "#D0E8F8", "$type": "color" }
        }
      },
      "spacing": {
        "0":    { "$value": "0rem", "$type": "dimension" },
        "0.5":  { "$value": "0.125rem", "$type": "dimension" },
        "1":    { "$value": "0.25rem", "$type": "dimension" },
        "1.5":  { "$value": "0.375rem", "$type": "dimension" },
        "2":    { "$value": "0.5rem", "$type": "dimension" },
        "3":    { "$value": "0.75rem", "$type": "dimension" },
        "4":    { "$value": "1rem", "$type": "dimension" },
        "5":    { "$value": "1.25rem", "$type": "dimension" },
        "6":    { "$value": "1.5rem", "$type": "dimension" },
        "8":    { "$value": "2rem", "$type": "dimension" },
        "10":   { "$value": "2.5rem", "$type": "dimension" },
        "12":   { "$value": "3rem", "$type": "dimension" },
        "16":   { "$value": "4rem", "$type": "dimension" },
        "20":   { "$value": "5rem", "$type": "dimension" },
        "24":   { "$value": "6rem", "$type": "dimension" },
        "32":   { "$value": "8rem", "$type": "dimension" }
      },
      "radius": {
        "none": { "$value": "0", "$type": "dimension" },
        "xs":   { "$value": "2px", "$type": "dimension" },
        "sm":   { "$value": "4px", "$type": "dimension" },
        "md":   { "$value": "8px", "$type": "dimension" },
        "lg":   { "$value": "12px", "$type": "dimension" },
        "xl":   { "$value": "16px", "$type": "dimension" },
        "2xl":  { "$value": "24px", "$type": "dimension" },
        "full": { "$value": "9999px", "$type": "dimension" }
      },
      "typography": {
        "fontFamily": {
          "display": { "$value": "'Instrument Serif', Georgia, 'Times New Roman', serif", "$type": "fontFamily" },
          "body":    { "$value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif", "$type": "fontFamily" },
          "mono":    { "$value": "'JetBrains Mono', 'SF Mono', 'Fira Code', monospace", "$type": "fontFamily" }
        },
        "fontSize": {
          "2xs":  { "$value": "0.6875rem", "$type": "dimension" },
          "xs":   { "$value": "0.75rem", "$type": "dimension" },
          "sm":   { "$value": "0.875rem", "$type": "dimension" },
          "base": { "$value": "1rem", "$type": "dimension" },
          "lg":   { "$value": "1.125rem", "$type": "dimension" },
          "xl":   { "$value": "1.25rem", "$type": "dimension" },
          "2xl":  { "$value": "1.5rem", "$type": "dimension" },
          "3xl":  { "$value": "2rem", "$type": "dimension" },
          "4xl":  { "$value": "2.5rem", "$type": "dimension" }
        },
        "fontWeight": {
          "regular":  { "$value": 400, "$type": "fontWeight" },
          "medium":   { "$value": 500, "$type": "fontWeight" },
          "semibold": { "$value": 600, "$type": "fontWeight" },
          "bold":     { "$value": 700, "$type": "fontWeight" }
        },
        "lineHeight": {
          "none":    { "$value": 1, "$type": "number" },
          "tight":   { "$value": 1.15, "$type": "number" },
          "snug":    { "$value": 1.3, "$type": "number" },
          "normal":  { "$value": 1.5, "$type": "number" },
          "relaxed": { "$value": 1.65, "$type": "number" }
        }
      },
      "motion": {
        "duration": {
          "instant":  { "$value": "60ms", "$type": "duration" },
          "fast":     { "$value": "120ms", "$type": "duration" },
          "normal":   { "$value": "200ms", "$type": "duration" },
          "slow":     { "$value": "350ms", "$type": "duration" },
          "slower":   { "$value": "500ms", "$type": "duration" },
          "dramatic": { "$value": "700ms", "$type": "duration" }
        },
        "easing": {
          "standard":   { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" },
          "emphasis":   { "$value": "cubic-bezier(0.2, 0, 0, 1.2)", "$type": "cubicBezier" },
          "decelerate": { "$value": "cubic-bezier(0, 0, 0, 1)", "$type": "cubicBezier" },
          "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" }
        }
      }
    },

    "semantic": {
      "color": {
        "bg": {
          "canvas":   { "$value": "{meridian.primitive.color.neutral.50}", "$type": "color" },
          "default":  { "$value": "{meridian.primitive.color.neutral.100}", "$type": "color" },
          "subtle":   { "$value": "{meridian.primitive.color.neutral.150}", "$type": "color" },
          "muted":    { "$value": "{meridian.primitive.color.neutral.200}", "$type": "color" },
          "elevated": { "$value": "{meridian.primitive.color.neutral.250}", "$type": "color" }
        },
        "text": {
          "primary":   { "$value": "{meridian.primitive.color.neutral.950}", "$type": "color" },
          "secondary": { "$value": "{meridian.primitive.color.neutral.700}", "$type": "color" },
          "tertiary":  { "$value": "{meridian.primitive.color.neutral.500}", "$type": "color" },
          "disabled":  { "$value": "{meridian.primitive.color.neutral.400}", "$type": "color" }
        },
        "accent": {
          "default": { "$value": "{meridian.primitive.color.amber.600}", "$type": "color" },
          "hover":   { "$value": "{meridian.primitive.color.amber.700}", "$type": "color" },
          "text":    { "$value": "{meridian.primitive.color.amber.700}", "$type": "color" },
          "subtle":  { "$value": "{meridian.primitive.color.amber.50}", "$type": "color" }
        },
        "border": {
          "default": { "$value": "{meridian.primitive.color.neutral.250}", "$type": "color" },
          "subtle":  { "$value": "{meridian.primitive.color.neutral.200}", "$type": "color" },
          "strong":  { "$value": "{meridian.primitive.color.neutral.400}", "$type": "color" }
        },
        "success": {
          "default": { "$value": "{meridian.primitive.color.teal.600}", "$type": "color" },
          "text":    { "$value": "{meridian.primitive.color.teal.700}", "$type": "color" },
          "subtle":  { "$value": "{meridian.primitive.color.teal.50}", "$type": "color" }
        },
        "danger": {
          "default": { "$value": "{meridian.primitive.color.red.500}", "$type": "color" },
          "text":    { "$value": "{meridian.primitive.color.red.700}", "$type": "color" },
          "subtle":  { "$value": "{meridian.primitive.color.red.50}", "$type": "color" }
        }
      },
      "radius": {
        "interactive": { "$value": "{meridian.primitive.radius.md}", "$type": "dimension" },
        "container":   { "$value": "{meridian.primitive.radius.lg}", "$type": "dimension" },
        "surface":     { "$value": "{meridian.primitive.radius.xl}", "$type": "dimension" },
        "badge":       { "$value": "{meridian.primitive.radius.full}", "$type": "dimension" }
      }
    },

    "component": {
      "button": {
        "height": {
          "sm": { "$value": "2rem", "$type": "dimension" },
          "md": { "$value": "2.5rem", "$type": "dimension" },
          "lg": { "$value": "3rem", "$type": "dimension" }
        },
        "radius": { "$value": "{meridian.semantic.radius.interactive}", "$type": "dimension" },
        "fontSize": { "$value": "{meridian.primitive.typography.fontSize.sm}", "$type": "dimension" },
        "fontWeight": { "$value": "{meridian.primitive.typography.fontWeight.medium}", "$type": "fontWeight" }
      },
      "input": {
        "height": { "$value": "2.5rem", "$type": "dimension" },
        "radius": { "$value": "{meridian.semantic.radius.interactive}", "$type": "dimension" },
        "fontSize": { "$value": "{meridian.primitive.typography.fontSize.sm}", "$type": "dimension" }
      },
      "card": {
        "radius": { "$value": "{meridian.semantic.radius.container}", "$type": "dimension" },
        "padding": { "$value": "{meridian.primitive.spacing.6}", "$type": "dimension" }
      },
      "badge": {
        "height": { "$value": "1.5rem", "$type": "dimension" },
        "radius": { "$value": "{meridian.semantic.radius.badge}", "$type": "dimension" },
        "fontSize": { "$value": "{meridian.primitive.typography.fontSize.xs}", "$type": "dimension" }
      },
      "nav": {
        "height": { "$value": "3.5rem", "$type": "dimension" }
      },
      "modal": {
        "width": {
          "sm": { "$value": "420px", "$type": "dimension" },
          "md": { "$value": "560px", "$type": "dimension" },
          "lg": { "$value": "720px", "$type": "dimension" }
        },
        "radius": { "$value": "{meridian.semantic.radius.surface}", "$type": "dimension" }
      }
    }
  }
}
