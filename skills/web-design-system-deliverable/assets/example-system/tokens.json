{
  "name": "Northstar Design System",
  "client": "Asteron",
  "tagline": "Editorial clarity for modern product teams",
  "themes": {
    "light": {
      "color": {
        "bg": {
          "canvas": "#fcfbf8",
          "surface": "rgba(255,255,255,0.72)",
          "elevated": "#ffffff"
        },
        "fg": {
          "strong": "#15181d",
          "default": "#1c2128",
          "muted": "#415061",
          "subtle": "#68788d"
        },
        "accent": {
          "default": "#9f5a44",
          "hover": "#7d4735",
          "contrast": "#fff9f7"
        },
        "status": {
          "success": "#285849",
          "warning": "#9f6d17",
          "danger": "#8d3440"
        }
      }
    },
    "dark": {
      "color": {
        "bg": {
          "canvas": "#111418",
          "surface": "rgba(22,26,31,0.84)",
          "elevated": "#1a2027"
        },
        "fg": {
          "strong": "#f6efe7",
          "default": "#edf1f5",
          "muted": "#c1cad2",
          "subtle": "#8c99a6"
        },
        "accent": {
          "default": "#d89984",
          "hover": "#e7ad99",
          "contrast": "#221915"
        },
        "status": {
          "success": "#8ec8ae",
          "warning": "#f4c675",
          "danger": "#f1a7b1"
        }
      }
    }
  },
  "typography": {
    "display": "Iowan Old Style, Palatino Linotype, Book Antiqua, Georgia, serif",
    "body": "Avenir Next, Segoe UI, Helvetica Neue, sans-serif",
    "mono": "IBM Plex Mono, SFMono-Regular, Consolas, monospace",
    "scale": ["0.75rem", "0.875rem", "1rem", "1.125rem", "1.375rem", "1.75rem", "2.5rem", "clamp(3.25rem, 8vw, 5.5rem)"]
  },
  "spacing": ["0.25rem", "0.5rem", "0.75rem", "1rem", "1.5rem", "2rem", "3rem", "4rem", "6rem"],
  "radius": ["0.5rem", "0.9rem", "1.4rem", "999px"],
  "motion": {
    "fast": "120ms",
    "base": "180ms",
    "slow": "280ms",
    "easing": "cubic-bezier(0.2, 0.8, 0.2, 1)"
  }
}
