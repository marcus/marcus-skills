{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "relayBureau": {
    "$description": "Relay Bureau design tokens",
    "primitive": {
      "color": {
        "paper": {
          "0": { "$value": "#FCFBF8", "$type": "color" },
          "1": { "$value": "#F3EFE6", "$type": "color" },
          "2": { "$value": "#E3DCCF", "$type": "color" }
        },
        "ink": {
          "0": { "$value": "#0E1013", "$type": "color" },
          "1": { "$value": "#16191F", "$type": "color" },
          "2": { "$value": "#232831", "$type": "color" },
          "3": { "$value": "#3B4350", "$type": "color" },
          "4": { "$value": "#636D7C", "$type": "color" }
        },
        "cobalt": {
          "0": { "$value": "#EDF2FF", "$type": "color" },
          "1": { "$value": "#D9E5FF", "$type": "color" },
          "3": { "$value": "#5B86FF", "$type": "color" },
          "4": { "$value": "#315FFF", "$type": "color" }
        },
        "moss": {
          "0": { "$value": "#EBF0E8", "$type": "color" },
          "1": { "$value": "#D3DDCF", "$type": "color" },
          "3": { "$value": "#5E705A", "$type": "color" }
        },
        "ember": {
          "0": { "$value": "#FFF0E8", "$type": "color" },
          "1": { "$value": "#F5D0BE", "$type": "color" },
          "3": { "$value": "#BA6434", "$type": "color" }
        },
        "gold": {
          "0": { "$value": "#FFF7DB", "$type": "color" },
          "2": { "$value": "#C7A852", "$type": "color" }
        }
      },
      "spacing": {
        "1": { "$value": "0.25rem", "$type": "dimension" },
        "2": { "$value": "0.5rem", "$type": "dimension" },
        "3": { "$value": "0.75rem", "$type": "dimension" },
        "4": { "$value": "1rem", "$type": "dimension" },
        "6": { "$value": "1.5rem", "$type": "dimension" },
        "8": { "$value": "2rem", "$type": "dimension" },
        "12": { "$value": "3rem", "$type": "dimension" },
        "16": { "$value": "4rem", "$type": "dimension" }
      },
      "radius": {
        "hair": { "$value": "0.5rem", "$type": "dimension" },
        "control": { "$value": "0.9rem", "$type": "dimension" },
        "panel": { "$value": "1.4rem", "$type": "dimension" },
        "stage": { "$value": "2rem", "$type": "dimension" },
        "pill": { "$value": "999px", "$type": "dimension" }
      },
      "typography": {
        "fontFamily": {
          "sans": { "$value": "\"Bricolage Grotesque\", \"Avenir Next\", \"Segoe UI\", sans-serif", "$type": "fontFamily" },
          "serif": { "$value": "\"Fraunces\", Georgia, serif", "$type": "fontFamily" },
          "mono": { "$value": "\"IBM Plex Mono\", monospace", "$type": "fontFamily" }
        },
        "fontSize": {
          "body": { "$value": "1rem", "$type": "dimension" },
          "lead": { "$value": "1.25rem", "$type": "dimension" },
          "title": { "$value": "clamp(2rem, 1.42rem + 1.9vw, 3.3rem)", "$type": "dimension" },
          "hero": { "$value": "clamp(4.75rem, 3rem + 5vw, 8.6rem)", "$type": "dimension" }
        }
      },
      "motion": {
        "duration": {
          "fast": { "$value": "110ms", "$type": "duration" },
          "standard": { "$value": "180ms", "$type": "duration" },
          "expressive": { "$value": "280ms", "$type": "duration" }
        },
        "easing": {
          "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" },
          "expressive": { "$value": "cubic-bezier(0.18, 0.84, 0.32, 1)", "$type": "cubicBezier" }
        }
      }
    },
    "semantic": {
      "light": {
        "background": {
          "canvas": { "$value": "{relayBureau.primitive.color.paper.0}", "$type": "color" },
          "panel": { "$value": "#FFFFFF", "$type": "color" },
          "inverse": { "$value": "{relayBureau.primitive.color.ink.1}", "$type": "color" }
        },
        "text": {
          "strong": { "$value": "{relayBureau.primitive.color.ink.1}", "$type": "color" },
          "soft": { "$value": "{relayBureau.primitive.color.ink.3}", "$type": "color" },
          "faint": { "$value": "{relayBureau.primitive.color.ink.4}", "$type": "color" },
          "inverse": { "$value": "#F7F8FB", "$type": "color" }
        },
        "border": {
          "subtle": { "$value": "rgba(20, 25, 31, 0.08)", "$type": "color" },
          "strong": { "$value": "rgba(20, 25, 31, 0.16)", "$type": "color" }
        },
        "accent": {
          "primary": { "$value": "{relayBureau.primitive.color.cobalt.4}", "$type": "color" },
          "soft": { "$value": "{relayBureau.primitive.color.cobalt.0}", "$type": "color" }
        },
        "state": {
          "success": { "$value": "{relayBureau.primitive.color.moss.3}", "$type": "color" },
          "warning": { "$value": "{relayBureau.primitive.color.gold.2}", "$type": "color" },
          "danger": { "$value": "{relayBureau.primitive.color.ember.3}", "$type": "color" }
        }
      },
      "dark": {
        "background": {
          "canvas": { "$value": "#0F1216", "$type": "color" },
          "panel": { "$value": "#181D23", "$type": "color" },
          "inverse": { "$value": "#F4F3EF", "$type": "color" }
        },
        "text": {
          "strong": { "$value": "#F3F5F8", "$type": "color" },
          "soft": { "$value": "#C1C7D0", "$type": "color" },
          "faint": { "$value": "#8E98A7", "$type": "color" }
        }
      }
    },
    "component": {
      "button": {
        "primaryRadius": { "$value": "{relayBureau.primitive.radius.pill}", "$type": "dimension" },
        "secondaryRadius": { "$value": "{relayBureau.primitive.radius.control}", "$type": "dimension" },
        "height": { "$value": "3rem", "$type": "dimension" }
      },
      "panel": {
        "radius": { "$value": "{relayBureau.primitive.radius.panel}", "$type": "dimension" },
        "padding": { "$value": "clamp(1.1rem, 0.8rem + 0.9vw, 1.8rem)", "$type": "dimension" }
      },
      "stage": {
        "radius": { "$value": "{relayBureau.primitive.radius.stage}", "$type": "dimension" }
      }
    }
  }
}
