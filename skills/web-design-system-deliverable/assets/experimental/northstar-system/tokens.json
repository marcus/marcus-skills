{
  "name": "Northstar Design System",
  "client": "Asteron",
  "tagline": "Editorial clarity for modern product teams",
  "themes": {
    "light": {
      "color": {
        "bg": {
          "canvas": "#fcfbf8",
          "surface": "rgba(255,255,255,0.72)",
          "elevated": "#ffffff",
          "soft": "#f6f2eb",
          "contrast": "#15181d"
        },
        "fg": {
          "strong": "#15181d",
          "default": "#1c2128",
          "muted": "#415061",
          "subtle": "#68788d",
          "contrast": "#f9fafb"
        },
        "border": {
          "subtle": "rgba(38,47,58,0.12)",
          "strong": "rgba(38,47,58,0.24)",
          "contrast": "rgba(255,255,255,0.16)"
        },
        "accent": {
          "default": "#9f5a44",
          "hover": "#7d4735",
          "soft": "#f2e1da",
          "contrast": "#fff9f7"
        },
        "status": {
          "success": "#285849",
          "success-soft": "#dbeadf",
          "warning": "#9f6d17",
          "warning-soft": "#f5e7c6",
          "danger": "#8d3440",
          "danger-soft": "#f6dfe4",
          "info": "#415061",
          "info-soft": "#e5ebf0"
        },
        "focus": {
          "default": "rgba(184,106,79,0.4)",
          "line": "rgba(184,106,79,0.72)"
        }
      }
    },
    "dark": {
      "color": {
        "bg": {
          "canvas": "#111418",
          "surface": "rgba(22,26,31,0.84)",
          "elevated": "#1a2027",
          "soft": "#181c22",
          "contrast": "#f6efe7"
        },
        "fg": {
          "strong": "#f6efe7",
          "default": "#edf1f5",
          "muted": "#c1cad2",
          "subtle": "#8c99a6",
          "contrast": "#111418"
        },
        "border": {
          "subtle": "rgba(235,241,245,0.1)",
          "strong": "rgba(235,241,245,0.22)",
          "contrast": "rgba(17,20,24,0.24)"
        },
        "accent": {
          "default": "#d89984",
          "hover": "#e7ad99",
          "soft": "rgba(216,153,132,0.16)",
          "contrast": "#221915"
        },
        "status": {
          "success": "#8ec8ae",
          "success-soft": "rgba(92,146,123,0.18)",
          "warning": "#f4c675",
          "warning-soft": "rgba(187,131,32,0.22)",
          "danger": "#f1a7b1",
          "danger-soft": "rgba(184,72,87,0.18)",
          "info": "#a8b4c0",
          "info-soft": "rgba(168,180,192,0.16)"
        },
        "focus": {
          "default": "rgba(231,173,153,0.34)",
          "line": "rgba(231,173,153,0.72)"
        }
      }
    }
  },
  "typography": {
    "display": "Iowan Old Style, Palatino Linotype, Book Antiqua, Georgia, serif",
    "body": "Avenir Next, Segoe UI, Helvetica Neue, sans-serif",
    "mono": "IBM Plex Mono, SFMono-Regular, Consolas, monospace",
    "scale": ["0.75rem", "0.875rem", "1rem", "1.125rem", "1.375rem", "1.75rem", "2.5rem", "clamp(3.25rem, 8vw, 5.5rem)"],
    "leading": {
      "tight": 1.08,
      "snug": 1.25,
      "body": 1.62
    },
    "tracking": {
      "tight": "-0.03em",
      "soft": "0.02em",
      "label": "0.12em"
    }
  },
  "spacing": ["0.25rem", "0.5rem", "0.75rem", "1rem", "1.5rem", "2rem", "3rem", "4rem", "6rem"],
  "radius": ["0.5rem", "0.9rem", "1.4rem", "999px"],
  "border": {
    "thin": "1px",
    "strong": "1.5px"
  },
  "shadow": {
    "soft": "0 12px 40px rgba(20,25,33,0.08)",
    "elevated": "0 22px 60px rgba(20,25,33,0.14)"
  },
  "motion": {
    "duration": {
      "micro": "60ms",
      "fast": "120ms",
      "base": "180ms",
      "moderate": "280ms",
      "slow": "400ms",
      "dramatic": "600ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "emphasis": "cubic-bezier(0.16, 1, 0.3, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "stagger-delay": "60ms"
  },
  "layout": {
    "content-narrow": "46rem",
    "content-wide": "76rem",
    "grid-gutter": "clamp(1rem, 2vw, 2rem)"
  }
}
