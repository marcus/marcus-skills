{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "aether": {
    "$description": "Aether OS Design Tokens — High-agency kinetic system",
    "primitive": {
      "color": {
        "ink": {
          "950": { "$value": "#050505", "$type": "color" },
          "900": { "$value": "#0A0A0A", "$type": "color" },
          "800": { "$value": "#141414", "$type": "color" },
          "700": { "$value": "#1F1F1F", "$type": "color" }
        },
        "paper": {
          "50":  { "$value": "#F9F9F9", "$type": "color" },
          "100": { "$value": "#F0F0F0", "$type": "color" },
          "200": { "$value": "#E0E0E0", "$type": "color" }
        },
        "neon": {
          "500": { "$value": "#00FF9C", "$type": "color" },
          "600": { "$value": "#00E68A", "$type": "color" },
          "400": { "$value": "#33FFAF", "$type": "color" }
        }
      },
      "typography": {
        "font": {
          "agency":    { "$value": "'Instrument Serif', serif", "$type": "fontFamily" },
          "precision": { "$value": "'Inter Tight', sans-serif", "$type": "fontFamily" },
          "state":     { "$value": "'Fragment Mono', monospace", "$type": "fontFamily" }
        }
      },
      "motion": {
        "duration": {
          "kinetic": { "$value": "200ms", "$type": "duration" },
          "snappy":  { "$value": "150ms", "$type": "duration" }
        },
        "ease": {
          "elastic": { "$value": "cubic-bezier(0.19, 1, 0.22, 1)", "$type": "cubicBezier" }
        }
      }
    },
    "semantic": {
      "color": {
        "bg": {
          "canvas": { "$value": "{aether.primitive.color.ink.950}", "$type": "color" },
          "surface": { "$value": "{aether.primitive.color.ink.900}", "$type": "color" },
          "elevated": { "$value": "{aether.primitive.color.ink.800}", "$type": "color" }
        },
        "fg": {
          "primary": { "$value": "{aether.primitive.color.paper.50}", "$type": "color" },
          "secondary": { "$value": "{aether.primitive.color.paper.200}", "$type": "color" },
          "accent": { "$value": "{aether.primitive.color.neon.500}", "$type": "color" }
        },
        "border": {
          "subtle": { "$value": "{aether.primitive.color.ink.700}", "$type": "color" },
          "strong": { "$value": "{aether.primitive.color.paper.200}", "$type": "color" }
        }
      }
    }
  }
}
